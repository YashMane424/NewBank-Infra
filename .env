# ── PostGres Database ───────
DATASOURCE_URL=jdbc:postgresql://localhost:5432/newbank
DATASOURCE_USER=postgres
DATASOURCE_PASSWORD=password

# ── Secret Keys ───────
JWT_SECRET = This_is_springboot_project_secret_key_256bit_safe!!
JWT_REFRESH = This_is_springboot_project_refresh_key_256bit_safe!!

SPRING_PROFILE=docker

# ── Ports ───────
BACKEND_PORT=8080
FRONTEND_PORT=80